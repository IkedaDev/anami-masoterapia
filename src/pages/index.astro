---
import Layout from '../layouts/HomeLayout.astro';
import Hero from '../components/home/Hero.astro';
import Bio from '../components/home/Bio.astro';
import { hotelFeatures, contactInfo } from '../utils/data';
import HotelSection from '../components/home/HotelSection.astro';
import ServiceGrid from '../components/home/ServiceGrid.astro';
import CtaCard from '../components/home/CtaCard.astro';
import ContactSection from '../components/home/ContactSection.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3000/v1"; // Fallback para desarrollo local

let services = [];

try {
  const response = await fetch(`${API_URL}/services`);
  if (!response.ok) {
    throw new Error(`Error fetching services: ${response.statusText}`);
  }
  const result = await response.json();
  
  if (result.success && Array.isArray(result.data)) {
    services = result.data.map((service: any) => ({
      name: service.name,
      duration: `${service.durationMin} min`,
      description: service.description || "",
      price: `$${service.basePrice.toLocaleString('es-CL')} CLP`
    }));
  } else {
    console.error("Formato de respuesta de API inesperado:", result);
  }
} catch (error) {
  console.error("Fallo al obtener servicios desde el backend durante el build:", error);

}

---
<Layout 
    title="Masoterapia y Masajes Descontracturantes en Temuco | Anami" 
    description="..."
>
    <section id="inicio">
        <Hero
            title="Bienestar y equilibrio"
            subtitle="Masoterapia profesional en Temuco y Padre las Casas. Un espacio diseñado para reconectar con tu cuerpo."
            imageUrl="https://i.imgur.com/G48cSaP.jpeg"
        />
    </section>

    <section id="bio">
        <Bio
            name="Hola, soy Anette"
            subtitle="Masoterapeuta Certificada"
            description="El masaje no es solo una técnica, es una forma de comunicación silenciosa. Con 3 años de experiencia, me dedico a crear espacios de pausa en un mundo acelerado, especializándome en aliviar la tensión crónica y restaurar la vitalidad."
            imageUrl="https://raw.githubusercontent.com/IkedaDev/anami-masoterapia-old/refs/heads/main/src/assets/images/p2-s2-1.jpeg"
        />
    </section>

    <section id="servicios">
    <ServiceGrid services={services} />
    </section>

    <section id="hotel">
        <HotelSection 
        title="Experiencia Tierra del Sur"
        description="Complementa tu estadía con un masaje express. Sesiones diseñadas para revitalizar tu energía después de un día de turismo o spa. El complemento perfecto para tu descanso."
        imageUrl="https://raw.githubusercontent.com/IkedaDev/anami-masoterapia-old/refs/heads/main/src/assets/images/p3-s1-1.jpg"
        features={hotelFeatures}
        />
    </section>

    <section id="reserva">
        <CtaCard
            title="Reserva tu momento"
            text="Regálate un respiro y desconecta del estrés diario. Un espacio diseñado para tu bienestar total."
            buttonText="Agendar ahora"
            imageUrl="https://i.imgur.com/d3kIHg2.jpeg"
        />
    </section>
    <section id="contacto">
        <ContactSection
        phone={contactInfo.phone}
        email={contactInfo.email}
        instagram={contactInfo.instagram}
        address={contactInfo.address}
        />
    </section>
</Layout>
    