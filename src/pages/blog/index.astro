---
// src/pages/blog/index.astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/HomeLayout.astro';
import BlogCard from '../../components/home/BlogCard.astro';

const posts = await getCollection('blog');
// Ordenamos por fecha descendente
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout 
  title="Blog de Bienestar | Anami Masoterapia"
  description="Consejos sobre masoterapia, cuidado personal y relajación en Temuco."
>
  <section class="an-blog-page">
    <header class="an-blog-page__header">
      <h1 class="an-blog-page__title">Nuestro Blog</h1>
      <p class="an-blog-page__subtitle">Espacio de bienestar y autocuidado</p>
    </header>

    <div class="an-blog-page__grid">
      {sortedPosts.map((post) => (
        <BlogCard
          title={post.data.title}
          excerpt={post.data.description}
        imageUrl={post.data.image}
          linkHref={`/blog/${post.slug}`}
          date={post.data.pubDate.toLocaleDateString('es-CL', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          })}
        />
      ))}
    </div>
  </section>
</Layout>

<style lang="scss">
  @use "@ikedadev/anami-ui/scss/abstracts/colors" as *;
  @use "@ikedadev/anami-ui/scss/abstracts/variables" as *;

  .an-blog-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8rem 3.2rem;

    &__header {
      text-align: center;
      margin-bottom: 8rem;
    }

    &__title {
      font-size: 5.6rem;
      font-weight: $font-weight-light;
      color: clr('text', 'main');
      margin-bottom: 1.6rem;
    }

    &__subtitle {
      font-size: 1.92rem;
      color: clr('brand', 'primary');
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(35rem, 1fr));
      gap: 4.8rem;
    }

    @media (max-width: 768px) {
      padding: 4.8rem 2rem;
      &__title { font-size: 4rem; }
      &__grid { grid-template-columns: 1fr; }
    }
  }
</style>