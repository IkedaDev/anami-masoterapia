---
import Layout from '../layouts/HomeLayout.astro';
import AnamiCalendar from '../presentation/components/Calendar/AnamiCalendar.jsx';

// Importamos estilos para asegurar consistencia
import '../styles/global.css';
---

<Layout 
    title="Agenda Virtual" 
    description="Gestión de citas y disponibilidad de Anami Masoterapia."
>
    <!-- Contenedor principal con estilo -->
    <div class="agenda-page-wrapper">
        <div class="agenda-container">
            
            <div class="agenda-header">
                <span class="an-text--subtitle">Agenda</span>
                <h1 class="an-text--h1">
                    Calendario de Citas
                </h1>
            </div>

            <AnamiCalendar client:only="react" />
            
        </div>
    </div>
</Layout>

<style>
    .agenda-page-wrapper {
        background-color: var(--anami-bg-body, #FFFCFA);
        min-height: 100vh;
        padding: 3rem 0;
    }

    .agenda-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    @media (min-width: 640px) {
        .agenda-container { padding: 0 1.5rem; }
    }
    @media (min-width: 1024px) {
        .agenda-container { padding: 0 2rem; }
    }

    .agenda-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    @media (min-width: 768px) {
        .agenda-title {
            font-size: 3rem; /* text-5xl */
        }
    }
</style>