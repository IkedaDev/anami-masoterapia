---
interface Props {
  logo: string;
  links: { text: string; href: string }[];
}

const { logo, links } = Astro.props;
---

<header class="an-navbar">
  <nav class="an-navbar__container">
    <h1 class="an-navbar__logo">
        <a href="/">{logo}</a>
    </h1>

    <div class="an-navbar__links" id="nav-links">
      {links.map((link) => (
        <a href={link.href} class="an-navbar__link">
          {link.text}
        </a>
      ))}
    </div>

    <button class="an-navbar__menu-btn" id="menu-toggle" aria-label="Menu">
      <span class="hamburger-box">
        <span class="hamburger-inner"></span>
      </span>
    </button>
  </nav>
</header>

<style lang="scss">
  @use "@ikedadev/anami-ui/scss/abstracts/colors" as *;
  @use "@ikedadev/anami-ui/scss/abstracts/variables" as *;

  .an-navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid clr('brand', 'secondary');
    background: rgba(clr('bg', 'body'), 0.95);
    backdrop-filter: blur(8px);
    transition: $transition-base;

    &__container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 2rem 3rem; // Aumentamos padding vertical
      max-width: 1300px;
      margin: 0 auto;

      @media (max-width: 768px) {
        padding: 1.2rem 1.5rem; // Padding lateral móvil del original
      }
    }

    // Mixin local para evitar repetición de la animación de la línea
    @mixin underline-animation {
      position: relative;
      &::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 1px;
        background: clr('brand', 'primary');
        transition: width 0.3s ease;
      }
      &:hover {
        color: clr('brand', 'primary');
        &::after {
          width: 100%;
        }
      }
    }

    &__logo {
      font-size: 2.24rem; // Aumentado de 1.4rem (ahora 18px)
      font-weight: $font-weight-medium;
      color: clr('text', 'main');
      text-decoration: none;
      letter-spacing: -0.03em;
      transition: $transition-base;
      display: inline-block;
      
      @include underline-animation; // Aplicamos la misma animación que el menú
    }

    &__links {
      display: flex;
      gap: 3.2rem; // Aumentamos el espacio entre links
      align-items: center;

      @media (max-width: 768px) {
        display: none;
        position: absolute;
        top: 100%; left: 0; width: 100%; height: 100vh;
        flex-direction: column; justify-content: center;
        background: clr('bg', 'surface');
        transition: transform 0.3s ease-out;
        transform: translateX(-100%);
        &.is-open {
          display: flex;
          transform: translateX(0);
        }
      }
    }

    &__link {
      text-decoration: none;
      color: clr('text', 'main');
      font-size: 1.52rem; // Aumentado de 0.95rem (ahora 14px)
      font-weight: $font-weight-light;
      transition: color 0.3s ease;
      
      @include underline-animation;

      @media (max-width: 768px) {
        font-size: 2.4rem; // 24px en móvil
        font-weight: $font-weight-regular;
      }
    }

    /* --- LÓGICA DE HAMBURGER SLIDER CORREGIDA --- */
    &__menu-btn {
      display: none;
      @media (max-width: 768px) { display: flex; align-items: center; justify-content: center; }
      
      padding: 1.2rem;
      cursor: pointer;
      background-color: transparent;
      border: 0;
      margin: 0;
      transition: opacity 0.15s linear;

      &:hover { opacity: 0.8; }

      .hamburger-box {
        width: 2.4rem; // 24px
        height: 1.42rem; // 19.2px
        display: inline-block;
        position: relative;
      }

      .hamburger-inner {
        display: block;
        top: 50%;
        // COMPENSACIÓN: mitad del alto (0.32rem / 2) para centrado absoluto
        margin-top: -0.16rem; 
        
        &, &::before, &::after {
          width: 2.4rem;
          height: 0.32rem; // Grosor de las barras
          background-color: clr('text', 'main');
          border-radius: 4px;
          position: absolute;
          transition-property: transform;
          transition-duration: 0.15s;
          transition-timing-function: ease;
        }

        &::before, &::after { content: ""; display: block; }

        // POSICIÓN INICIAL: 8px arriba y abajo
        &::before { top: -0.8rem; } 
        &::after { top: 0.8rem; } 

        transition-timing-function: cubic-bezier(0.55, 0.055, 0.675, 0.19);
      }

      // ESTADO ACTIVO: La "X" perfecta
      &.is-active {
        .hamburger-inner {
          // Gira la barra central
          transform: rotate(45deg);
          transition-delay: 0.12s;
          transition-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);

          &::before {
            // Se desliza al centro y gira
            top: 0;
            opacity: 0; // En el slider original la de arriba se oculta o se fusiona
            transition: top 0.1s ease, opacity 0.1s 0.12s linear;
          }

          &::after {
            // Sube al centro y gira -90 (formando los -45 finales)
            top: 0;
            transform: rotate(-90deg);
            transition: top 0.1s ease, transform 0.22s 0.12s cubic-bezier(0.215, 0.61, 0.355, 1);
          }
        }
      }}
  }
</style>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const navLinks = document.getElementById('nav-links');

  menuToggle?.addEventListener('click', () => {
    const isOpen = navLinks?.classList.toggle('is-open');
    menuToggle?.classList.toggle('is-active');
    
    if (isOpen) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
  });

  const links = document.querySelectorAll('.an-navbar__link');
  links.forEach(link => {
    link.addEventListener('click', () => {
      navLinks?.classList.remove('is-open');
      menuToggle?.classList.remove('is-active');
      document.body.style.overflow = '';
    });
  });
</script>