---
// src/components/CtaCard.astro
interface Props {
  title?: string;
  text?: string;
  buttonText?: string;
  imageUrl?: string;
  phone?: string;
}

const { 
  title = "Reserva tu momento", 
  text = "Regálate un respiro y desconecta del estrés diario. Un espacio diseñado para tu bienestar total.",
  buttonText = "Agendar ahora",
  imageUrl = "https://i.imgur.com/G48cSaP.jpeg",
  phone = "56963564897"
} = Astro.props;
---

<section class="an-cta-premium">
  <div class="an-cta-premium__wrapper" data-cta-title={title} data-phone={phone}>
    <div class="an-cta-premium__bg">
      <img src={imageUrl} alt="Relajación Anami" loading="lazy" />
      <div class="an-cta-premium__overlay"></div>
    </div>

    <div class="an-cta-premium__panel">
      <div class="an-cta-premium__content">
        <span class="an-cta-premium__tag">Experiencia Wellness</span>
        <h2 class="an-cta-premium__title">{title}</h2>
        <p class="an-cta-premium__text">{text}</p>
        
        <button class="an-button-cta">
          <span>{buttonText}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use "sass:color";
  @use "@ikedadev/anami-ui/scss/abstracts/colors" as *;
  @use "@ikedadev/anami-ui/scss/abstracts/variables" as *;

  .an-cta-premium {
    padding: 9.6rem 3.2rem;
    
    &__wrapper {
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      border-radius: $radius-lg;
      overflow: hidden;
      min-height: 50rem;
      display: flex;
      align-items: center;
      cursor: pointer;
      box-shadow: $shadow-soft;

      // QUITAMOS el transform scale del wrapper para que la card interna no se mueva
      &:hover {
        .an-cta-premium__bg img { 
          transform: scale(1.08); // El fondo se sigue moviendo
        }
      }
    }

    &__bg {
      position: absolute;
      inset: 0;
      z-index: 1;
      overflow: hidden;
      
      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.2s cubic-bezier(0.165, 0.84, 0.44, 1); // Transición más suave
      }
    }

    &__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.1) 100%);
    }

    &__panel {
      position: relative;
      z-index: 2;
      width: 100%;
      padding: 0 8rem;

      @media (max-width: 768px) {
        padding: 0 3.2rem;
      }
    }

    &__content {
      background: rgba(clr('bg', 'surface'), 0.85);
      backdrop-filter: blur(12px);
      padding: 6.4rem;
      max-width: 55rem;
      border-radius: $radius-lg;
      border: 1px solid rgba(clr('brand', 'secondary'), 0.3);
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
      // Aseguramos que la card no herede ninguna transformación
      transform: translateZ(0); 

      @media (max-width: 768px) {
        max-width: 100%;
        padding: 4.8rem 3.2rem;
        background: clr('bg', 'surface');
        text-align: center;
      }
    }

    &__tag {
      display: block;
      font-size: 1.28rem;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: clr('brand', 'primary');
      font-weight: $font-weight-medium;
      margin-bottom: 1.6rem;
    }

    &__title {
      font-size: 4.8rem;
      color: clr('text', 'main');
      line-height: 1.1;
      margin-bottom: 2.4rem;
      font-weight: $font-weight-medium;
      letter-spacing: -0.02em;

      @media (max-width: 768px) { font-size: 3.2rem; }
    }

    &__text {
      font-size: 1.76rem;
      color: clr('text', 'light');
      line-height: 1.7;
      margin-bottom: 4rem;
      font-weight: $font-weight-light;
    }
  }

  .an-button-cta {
    background-color: clr('brand', 'primary');
    color: white;
    border: none;
    padding: 1.6rem 3.2rem;
    font-size: 1.6rem;
    font-weight: $font-weight-medium;
    border-radius: $radius-pill;
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
    transition: all 0.3s ease;
    cursor: pointer;

    svg { 
      transition: transform 0.3s ease; 
    }

    // ANIMACIÓN SOLO CUANDO EL MOUSE ESTÁ ENCIMA DEL BOTÓN
    &:hover {
      background-color: color.adjust(#c47f6b, $lightness: -5%);
      transform: translateY(-2px); // Pequeño levante del botón
      box-shadow: 0 8px 15px rgba(196, 127, 107, 0.3);

      svg { 
        transform: translateX(6px); 
      }
    }
  }
</style>

<script>
  // Lógica de agendamiento vía WhatsApp
  const ctaWrappers = document.querySelectorAll('.an-cta-premium__wrapper');
  
  ctaWrappers.forEach(wrapper => {
    wrapper.addEventListener('click', () => {
      // @ts-ignore
      const title = wrapper.dataset.ctaTitle;
      // @ts-ignore
      const phone = wrapper.dataset.phone;
      
      const message = encodeURIComponent(`¡Hola Anami! Me gustaría agendar mi momento de bienestar: ${title}.`);
      const whatsappUrl = `https://wa.me/${phone}?text=${message}`;
      
      window.open(whatsappUrl, '_blank');
    });
  });
</script>