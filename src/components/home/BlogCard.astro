---
// src/components/BlogCard.astro
interface Props {
  title: string;
  excerpt: string;
  imageUrl: string;
  linkHref: string;
  date: string;
}

const { title, excerpt, imageUrl, linkHref, date } = Astro.props;
---

<article class="an-blog-card">
  <a href={linkHref} class="an-blog-card__image-link">
    <img src={imageUrl} alt={title} class="an-blog-card__image" />
    <span class="an-blog-card__date">{date}</span>
  </a>
  <div class="an-blog-card__content">
    <h3 class="an-blog-card__title">{title}</h3>
    <p class="an-blog-card__excerpt">{excerpt}</p>
    <a href={linkHref} class="an-blog-card__link">
      Leer más
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</article>

<style lang="scss">
  @use "@ikedadev/anami-ui/scss/abstracts/colors" as *;
  @use "@ikedadev/anami-ui/scss/abstracts/variables" as *;

  .an-blog-card {
    background: clr('bg', 'surface');
    border-radius: $radius-lg;
    overflow: hidden;
    box-shadow: $shadow-soft;
    transition: $transition-base;
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid clr('brand', 'secondary');

    &:hover {
      transform: translateY(-5px);
      box-shadow: $shadow-hover;

      .an-blog-card__image { transform: scale(1.05); }
      .an-blog-card__link { color: clr('brand', 'primary'); }
    }

    &__image-link {
      position: relative;
      height: 24rem; // 15rem * 1.6
      overflow: hidden;
      display: block;
    }

    &__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    &__date {
      position: absolute;
      top: 1.6rem;
      right: 1.6rem;
      background: rgba(clr('bg', 'body'), 0.9);
      padding: 0.6rem 1.6rem;
      border-radius: $radius-pill;
      font-size: 1.12rem; // 0.7rem * 1.6
      font-weight: $font-weight-medium;
      color: clr('text', 'main');
      backdrop-filter: blur(4px);
    }

    &__content {
      padding: 3.2rem; // 2rem * 1.6
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    &__title {
      font-size: 2.56rem; // 1.6rem * 1.6
      font-weight: $font-weight-regular;
      margin: 0 0 1.6rem 0;
      color: clr('text', 'main');
      line-height: 1.3;
    }

    &__excerpt {
      font-size: 1.52rem; // 0.95rem * 1.6
      color: clr('text', 'light');
      line-height: 1.6;
      margin-bottom: 2.4rem;
      flex-grow: 1;
    }

    &__link {
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      text-decoration: none;
      color: clr('text', 'main');
      font-weight: $font-weight-medium;
      font-size: 1.44rem; // 0.9rem * 1.6
      transition: color 0.3s;

      svg { transition: transform 0.3s; }
      &:hover svg { transform: translateX(4px); }
    }
  }
</style>